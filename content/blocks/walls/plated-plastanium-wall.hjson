    hitEffect: explosion
    smokeEffect: smoke
    fragBullets: 12
    fragVelocityMin: 1.8
    fragVelocityMax: 3.2
    fragBullet: {
      type: ShrapnelBulletType
      damage: 12
      length: 70
      width: 12
      lifetime: 22
      fromColor: D3E285
      toColor: 8BA34F
      status: slow
      statusDuration: 30
      hitEffect: hitBulletSmall
    }
  }
  
researchCostMultiplier: 2
